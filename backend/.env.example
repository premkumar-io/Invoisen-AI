# ── Server ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── Database ─────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/Invoisen

# ── JWT ───────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace_with_64_char_hex_minimum_32_chars_required_here
JWT_REFRESH_SECRET=replace_with_different_64_char_hex_minimum_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Frontend URL ──────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:3000

# ── CORS (comma-separated) ────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Google OAuth (optional) ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# ── Email (Nodemailer) — optional in development ────────────────────────
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@Invoisen.com

# ── Invoice limits ────────────────────────────────────────────────────────
FREE_PLAN_MONTHLY_INVOICE_LIMIT=10
TRASH_RETENTION_DAYS=30

# ── Admin seed (optional) ───────────────────────────────────────────────────
SEED_ADMIN_EMAIL=admin@Invoisen.com
SEED_ADMIN_PASSWORD=ChangeMe123!
SEED_ADMIN_NAME=Invoisen Admin

# ── PDF (optional) ──────────────────────────────────────────────────────────
PUPPETEER_EXECUTABLE_PATH=
